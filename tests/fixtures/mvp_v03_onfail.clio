CONTRACT customer_risk
  SHAPE: {client: str, risk: enum(low|mid|high), reason: str}

STEP load_customers
  TAKES: file:      str
  GIVES: customers: List<{name: str, revenue: float}>
  MODE:  exact

STEP detect_churn
  TAKES:    customers: List<{name: str, revenue: float}>
  GIVES:    risks:     List<customer_risk>
  MODE:     judgment
  CACHE:    ttl(24h)
  ON_FAIL:  retry(3) then escalate then abort("churn detection failed")

FLOW retention
  load_customers(file="customers.csv")
    -> detect_churn(customers)

RESOURCES
  target:  claude-cli
  models:  [haiku, sonnet]
