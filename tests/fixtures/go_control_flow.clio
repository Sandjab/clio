CONTRACT risk_assessment
  SHAPE: {level: enum(low|mid|high), score: float}

STEP detect
  TAKES: x: str
  GIVES: assessment: risk_assessment
  MODE:  exact
  LANG:  go

STEP notify_team
  TAKES: x: str
  GIVES: ticket_id: str
  MODE:  exact
  LANG:  go

STEP store_record
  TAKES: x: str
  GIVES: stored: bool
  MODE:  exact
  LANG:  go

STEP archive
  TAKES: x: str
  GIVES: archived: bool
  MODE:  exact
  LANG:  go

STEP flag
  TAKES: x: str
  GIVES: flagged: bool
  MODE:  exact
  LANG:  go

FLOW pipeline
  detect(x="incoming")
  -> IF assessment.level == high:
       notify_team(x="incoming")
  ELSE:
       store_record(x="incoming")
  -> MATCH assessment.level:
       CASE low:  archive(x="incoming")
       CASE mid:  flag(x="incoming")
       CASE high: flag(x="incoming")

RESOURCES
  target: go
  models: [haiku]
