# parallel_review.clio — fan-out code review
#
# The centre of gravity is FOR EACH … PARALLEL: every changed file is reviewed
# concurrently, then every draft is triaged concurrently, and only the final
# summary joins the results back together.
#
# This is the shape `--target claude-workflow` exists for: it is the only target
# where PARALLEL is really parallel — each iteration becomes a Claude Code
# subagent, fanned out by `parallel()`. For comparison:
#
#   claude-workflow            real concurrency (parallel() over subagents)
#   claude-skill               serialized, with a warning
#   claude-cli / langgraph     rejected at compile time
#   python / go / swift / mcp-server   supported
#
# `list_changed_files` is an exact step with no `impl:` — under claude-workflow
# it is emitted as a pure-JS stub that throws until you fill it in (the workflow
# sandbox has no process, no network and no filesystem, so an `impl: shell`
# here would be refused with E_WF_003).

CONTRACT review_note
  SHAPE:  {file: str(max=200), severity: enum(blocker|major|minor|nit), finding: str(max=400)}

STEP list_changed_files
  TAKES: diff:  str
  GIVES: files: List<str>
  MODE:  exact

STEP review_file
  TAKES: file:  str
  GIVES: draft: str
  MODE:  judgment

STEP triage_finding
  TAKES: draft: str
  GIVES: note:  review_note
  MODE:  judgment

STEP summarize_review
  TAKES: notes:   List<review_note>
  GIVES: verdict: str
  MODE:  judgment

FLOW parallel_review
  TAKES: diff: str
  list_changed_files(diff=diff)
    -> FOR EACH f IN files PARALLEL AS drafts:
         review_file(file=f)
    -> FOR EACH d IN drafts PARALLEL AS notes:
         triage_finding(draft=d)
    -> summarize_review(notes=notes)
